# Copy this file to `.env.local` and use ONE network block at a time.
#
# For local testing of the Vercel project:
#   cd api
#   cp .env.example .env.local
#   # edit .env.local and uncomment one network block
#   npx vercel dev

COLLECTION_NAME=Fregs
NFTS_MAX_LIMIT=100

# ============================================================================
# Local Hardhat example
# Use this when `npx hardhat node` is running and contracts are deployed locally.
# These addresses come from `hardhat/deployment-status.json` in this repo.
# ============================================================================
# USE_LOCAL_DEPLOYMENT_FALLBACK=1
# API_RPC_URL=http://127.0.0.1:8545
# FREGS_ADDRESS=0x5FbDB2315678afecb367f032d93F642f64180aa3
# CHAIN_ID=31337

# ============================================================================
# Base Sepolia example
# Replace the placeholder contract addresses with your deployed Base Sepolia values.
# ============================================================================
API_RPC_URL=https://base-sepolia.g.alchemy.com/v2/
FREGS_ADDRESS=0x02c108083691468eB8bbA5890E91f74E5b2ad2cC
CHAIN_ID=84532

# ============================================================================
# Base Mainnet example
# Replace the placeholder contract addresses with your deployed Base mainnet values.
# ============================================================================
# API_RPC_URL=https://mainnet.base.org
# FREGS_ADDRESS=0xYOUR_BASE_MAINNET_FREGS_ADDRESS
# CHAIN_ID=8453
